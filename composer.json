{
    "name": "a-sabagh/laravel-enhance-enums",
    "description": "A lightweight Laravel package that adds a reusable Translatable trait for handling model translations with clean, consistent syntax.",
    "authors": [
        {
            "name": "a-sabagh",
            "email": "a.sabagh72@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^4.0|^5.0|^6.0|^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^8.0|^9.3|^10.4|^11.5"
    },
    "autoload": {
        "psr-4": {
            "Enhance\\Enums\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Enhance\\Enums\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Enhance\\Enums\\EEnumsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always --testdox ./tests",
        "pint:dirty": "vendor/bin/pint --dirty -v",
        "pint:verbose": "vendor/bin/pint -v"
    },
    "prefer-stable": true
}